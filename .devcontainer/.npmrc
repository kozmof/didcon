registry=https://npm.flatt.tech/
min-release-age=7
# Container-wide default: pnpm must not self-install the version from a
# project's "packageManager" field. That self-install re-enters the
# Island/Landlock sandbox and fails (E2BIG); use the image's pinned pnpm.
# Baked into /etc/npmrc by the Dockerfiles; a project .npmrc can override it.
manage-package-manager-versions=false
