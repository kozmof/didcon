
{
  "name": "didcon",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      // Option: specify versions explicitly
      "CLAUDE_CODE_VERSION": "latest",
      "CODEX_VERSION": "latest",
      "NPM_VERSION": "11.17.0",
      "ISLAND_REV": "05a9d699fbf30289fd2af4311becf38ceb334df2"
    }
  },
  "runArgs": [
    "--cap-drop=ALL",
    // iptables needs NET_RAW here, and su-exec needs SETUID/SETGID to switch to the dev user.
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=SETUID",
    "--cap-add=SETGID",
    "--security-opt=no-new-privileges:true",
    // large tests may need to increase this value.
    "--pids-limit=512",
    "--memory=8g",
    "--cpus=4",
    "--init"
  ],
  "overrideCommand": false,
  "remoteUser": "dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "-anthropic.claude-code",
        "-openai.chatgpt"
      ],
      "settings": {
        "workbench.colorCustomizations": {
          "titleBar.activeBackground": "#009e15",
          "titleBar.activeForeground": "#ffffff",
          "titleBar.inactiveBackground": "#141414"
        }
      }
    }
  },
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "GOTELEMETRY": "off"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "postCreateCommand": "/opt/scripts/install-safe-chain.sh"
}
