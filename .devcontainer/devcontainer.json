
{
  "name": "Devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "CLAUDE_CODE_VERSION": "latest"
    }
  },
  "runArgs": [
    "--cap-drop=ALL",
    // iptables needs NET_RAW here, and su-exec needs SETUID/SETGID to switch to the dev user.
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=SETUID",
    "--cap-add=SETGID",
    "--security-opt=no-new-privileges:true",
    // large tests may need to increase this value.
    "--pids-limit=512",
    "--init"
  ],
  "overrideCommand": false,
  "remoteUser": "dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "openai.chatgpt"
      ],
      "settings": {
        "workbench.colorCustomizations": {
          "titleBar.activeBackground": "#009e15",
          "titleBar.activeForeground": "#ffffff",
          "titleBar.inactiveBackground": "#141414"
        }
      }
    }
  },
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "GOTELEMETRY": "off"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "postCreateCommand": "wget -qO- https://github.com/AikidoSec/safe-chain/releases/latest/download/install-safe-chain.sh | sh"
}
